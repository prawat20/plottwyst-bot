# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/plottwyst

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Local Testing ─────────────────────────────────────────────────────────────
# Set to true to skip Gemini and use pre-written sample cases (no API key needed)
TEST_MODE=false

# ─── Game Settings (optional overrides) ────────────────────────────────────────
DISCUSSION_TIME=60
VOTING_TIME=30
GUESS_TIME=30
